# Server
PORT=4000

# PostgreSQL
# Option 1: single connection string
DATABASE_URL=postgres://postgres:postgres@localhost:5433/unilink

# Option 2: discrete fields (used if DATABASE_URL is not provided)
DB_HOST=localhost
DB_PORT=5433
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=unilink

# Auth
JWT_SECRET=change-this-in-production
